# =============================================================================
# 播客转小红书自动化工作流 — 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# =============================================================================

# -----------------------------------------------------------------------------
# LLM 配置
# -----------------------------------------------------------------------------

# 默认 LLM 提供商: openai / anthropic / ollama
DEFAULT_LLM_PROVIDER=ollama

# OpenAI API 配置
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (兼容 OpenAI 格式)
# 如需使用 DeepSeek，请设置以下变量并修改 DEFAULT_LLM_PROVIDER 为 openai
# 然后修改 OPENAI_API_KEY 和 OPENAI_BASE_URL 为 DeepSeek 的值
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Anthropic (Claude) API 配置
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama 本地服务配置
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# -----------------------------------------------------------------------------
# 语音转文字 (STT) 配置
# -----------------------------------------------------------------------------

# STT 提供商: whisper / faster-whisper / sensevoice / elevenlabs
STT_PROVIDER=whisper

# Whisper 模型配置
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ElevenLabs Scribe API 配置（可选）
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# -----------------------------------------------------------------------------
# 小红书发布配置
# -----------------------------------------------------------------------------

# 发布模式: rpa / semi-auto / manual
XIAOHONGSHU_PUBLISH_MODE=manual

# RPA 配置
XIAOHONGSHU_RPA_ENABLED=false
XIAOHONGSHU_CHROME_PROFILE=
XIAOHONGSHU_HEADLESS=false

# -----------------------------------------------------------------------------
# 系统配置
# -----------------------------------------------------------------------------

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 数据存储目录
DATA_DIR=./data

# 临时文件目录
TEMP_DIR=./data/temp

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 重试次数
MAX_RETRIES=3
